{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes":  [
      {
          "src": "^/$",
              "dest": "/public/thanks.html"
      },
    {
      "src": "/webhook/stripe",
      "dest": "/api/webhook/stripe.js"
    },
    {
      "src": "/health",
      "dest": "/api/health.js"
    },
    {
      "src": "/test-email",
      "dest": "/api/test-email.js"
    },
    {
      "src": "/test-passkit",
      "dest": "/api/test-passkit.js"
    },
    {
      "src": "/set-geofence",
      "dest": "/api/set-geofence.js"
    },
    {
      "src": "/create-member",
      "dest": "/api/create-member.js"
    },
    {
      "src": "/scan",
      "dest": "/api/scan.js"
    },
    {
      "src": "/scanner",
      "dest": "/public/scanner.html"
    },
    {
      "src": "/thanks",
      "dest": "/public/thanks.html"
    },
    {
      "src": "/cancel",
      "dest": "/public/cancel.html"
    },
    {
      "src": "/portal",
      "dest": "/api/portal.js"
    }
  ]
}

{
  "version": 2,
  "crons": [
    {
      "path": "/api/remind-inactive",
      "schedule": "0 15 * * *"
    }
  ],
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes":  [
      {
          "src": "^/$",
              "dest": "/public/thanks.html"
      },
    {
      "src": "/webhook/stripe",
      "dest": "/api/webhook/stripe.js"
    },
    {
      "src": "/health",
      "dest": "/api/health.js"
    },
    {
      "src": "/set-geofence",
      "dest": "/api/set-geofence.js"
    },
    {
      "src": "/create-member",
      "dest": "/api/create-member.js"
    },
    {
      "src": "/scan",
      "dest": "/api/scan.js",
      "headers": {
        "Cache-Control": "no-store, no-cache, must-revalidate, proxy-revalidate"
      }
    },
    {
      "src": "/scanner",
      "dest": "/public/scanner.html",
      "headers": { "Cache-Control": "no-cache, no-store, must-revalidate" }
    },
    {
      "src": "/thanks",
      "dest": "/public/thanks.html"
    },
    {
      "src": "/cancel",
      "dest": "/public/cancel.html"
    },
    {
      "src": "/portal",
      "dest": "/api/portal.js"
    },
    {
      "src": "/cleanup-member",
      "dest": "/api/cleanup-member.js"
    },
    {
      "src": "/setup-strip-image",
      "dest": "/api/setup-strip-image.js"
    },
    {
      "src": "/list-members",
      "dest": "/api/list-members.js"
    },
    {
      "src": "/fix-barcode",
      "dest": "/api/fix-barcode.js"
    },
    {
      "src": "/repair-member-visits",
      "dest": "/api/repair-member-visits.js"
    },
    {
      "src": "/remind-inactive",
      "dest": "/api/remind-inactive.js"
    }
  ]
}

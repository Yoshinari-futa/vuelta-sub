{
  "version": 2,
  "crons": [
    {
      "path": "/remind-inactive",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/daily-sales",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/weekly-sales",
      "schedule": "0 22 * * 0"
    },
    {
      "path": "/monthly-sales",
      "schedule": "0 22 1 * *"
    },
    {
      "path": "/customer-receipt-oku",
      "schedule": "0 22 * * *"
    }
  ],
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes":  [
      {
          "src": "^/$",
              "dest": "/public/thanks.html"
      },
    {
      "src": "/webhook/stripe",
      "dest": "/api/webhook/stripe.js"
    },
    {
      "src": "/health",
      "dest": "/api/health.js"
    },
    {
      "src": "/set-geofence",
      "dest": "/api/set-geofence.js"
    },
    {
      "src": "/create-member",
      "dest": "/api/create-member.js"
    },
    {
      "src": "/scan",
      "dest": "/api/scan.js",
      "headers": {
        "Cache-Control": "no-store, no-cache, must-revalidate, proxy-revalidate"
      }
    },
    {
      "src": "/scanner",
      "dest": "/public/scanner.html",
      "headers": { "Cache-Control": "no-cache, no-store, must-revalidate" }
    },
    {
      "src": "/thanks",
      "dest": "/public/thanks.html"
    },
    {
      "src": "/cancel",
      "dest": "/public/cancel.html"
    },
    {
      "src": "/portal",
      "dest": "/api/portal.js"
    },
    {
      "src": "/cleanup-member",
      "dest": "/api/cleanup-member.js"
    },
    {
      "src": "/list-members",
      "dest": "/api/list-members.js"
    },
    {
      "src": "/remind-inactive",
      "dest": "/api/remind-inactive.js"
    },
    {
      "src": "/daily-sales",
      "dest": "/api/daily-sales.js"
    },
    {
      "src": "/weekly-sales",
      "dest": "/api/weekly-sales.js"
    },
    {
      "src": "/monthly-sales",
      "dest": "/api/monthly-sales.js"
    },
    {
      "src": "/customer-receipt-oku",
      "dest": "/api/customer-receipt-oku.js"
    },
    {
      "src": "/concierge",
      "dest": "/public/concierge.html"
    },
    {
      "src": "/api/concierge-chat",
      "dest": "/api/concierge-chat.js"
    }
  ]
}

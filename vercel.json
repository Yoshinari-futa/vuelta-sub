{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/webhook/stripe",
      "dest": "/api/webhook/stripe.js"
    },
    {
      "src": "/health",
      "dest": "/api/health.js"
    },
    {
      "src": "/test-email",
      "dest": "/api/test-email.js"
    },
    {
      "src": "/test-passkit",
      "dest": "/api/test-passkit.js"
    },
    {
      "src": "/set-geofence",
      "dest": "/api/set-geofence.js"
    },
    {
      "src": "/thanks",
      "dest": "/public/thanks.html"
    }
  ]
}
